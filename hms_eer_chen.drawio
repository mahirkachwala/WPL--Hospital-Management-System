        <mxCell id='p2_title' value='Hospital Management System - Full Physical Schema from SQL Dump' style='text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=22;fontStyle=1' vertex='1' parent='1'><mxGeometry x='850' y='20' width='1600' height='30' as='geometry'/></mxCell>
        <mxCell id='p2_note' value='This page is generated from the actual SQL dump. The dump defines indexes and unique keys but does not declare physical FOREIGN KEY constraints; FK tags below are inferred from column names + the reviewed EER markdown.' style='shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656' vertex='1' parent='1'><mxGeometry x='2550' y='40' width='360' height='120' as='geometry'/></mxCell>
        <mxCell id='p2_admin' value='&lt;b&gt;ADMIN&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;color:#666&apos;&gt;Physical table: admin&lt;/font&gt;&lt;br/&gt;[PK] id : int(11) NOT NULL&lt;br/&gt;[CK] username : varchar(255) NOT NULL&lt;br/&gt;password : varchar(255) NOT NULL&lt;br/&gt;updationDate : datetime DEFAULT NULL' style='rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=6' vertex='1' parent='1'><mxGeometry x='40' y='180' width='740' height='140' as='geometry'/></mxCell>
        <mxCell id='p2_users' value='&lt;b&gt;USER&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;color:#666&apos;&gt;Physical table: users&lt;/font&gt;&lt;br/&gt;[PK] id : int(11) NOT NULL&lt;br/&gt;fullName : varchar(255) DEFAULT NULL&lt;br/&gt;[C] address : text DEFAULT NULL&lt;br/&gt;[C] city : varchar(255) DEFAULT NULL&lt;br/&gt;gender : varchar(50) DEFAULT NULL&lt;br/&gt;[CK] email : varchar(255) DEFAULT NULL&lt;br/&gt;password : varchar(255) DEFAULT NULL&lt;br/&gt;regDate : datetime NOT NULL DEFAULT current_timestamp()&lt;br/&gt;updationDate : datetime DEFAULT NULL' style='rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=6' vertex='1' parent='1'><mxGeometry x='830' y='180' width='740' height='202' as='geometry'/></mxCell>
